# ─────────────────────────────────────────────────────────────────────
# Stock Recommendations — environment template
# ─────────────────────────────────────────────────────────────────────
# Copy to backend/.env and fill in your keys. NEVER commit the real
# .env to git — it's in .gitignore for a reason.

# ─────── REQUIRED — auth + database ──────────────────────────────────

# Shared-secret for every /api/* endpoint. Generate something opaque:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
APP_API_KEY=

# Cloud SQL Postgres connection. For Cloud Run, use the Unix socket form:
#   postgresql://USER:PASS@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
# For local dev with TCP:
#   postgresql://USER:PASS@HOST:5432/DB
# For tests, an in-memory SQLite is fine:
#   sqlite:///:memory:
DATABASE_URL=

# ─────── REQUIRED — Alpaca broker ────────────────────────────────────

# Algo Trader Plus subscription strongly recommended for SIP feed + tape.
# Paper-trading API: app.alpaca.markets/paper/dashboard/overview
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Data feed: 'sip' for Algo Trader Plus full tape, 'iex' for free tier.
ALPACA_DATA_FEED=sip

# ─────── LIVE TRADING — DO NOT SET UNLESS YOU MEAN IT ────────────────
# All four of these must be set for ALPACA_LIVE=1 to be allowed.
# The boot guard in main.py refuses to start if any are missing.

ALPACA_LIVE=0
I_UNDERSTAND_LIVE_RISK=
CORS_ALLOW_ORIGINS=

# ─────── DUAL-SERVICE ARCHITECTURE ───────────────────────────────────
# Determines what scheduler jobs this process registers.
#   api      = HTTP API + scanner + signal generation + entries (default)
#   manager  = ONLY position management + reconciliation
# In production, run two Cloud Run services with different RUN_MODE.
RUN_MODE=api

# ─────── OPTIONAL — alt-data + ML ────────────────────────────────────

# Anthropic API key — enables the in-app Claude chat widget AND the
# AI judge layer (entry veto / news exit / sizing multiplier). Get one
# at console.anthropic.com (separate from claude.ai subscription).
ANTHROPIC_API_KEY=

# AI judge call-site modes. Each cycles: off | shadow | active
#   off     — never call Claude (default; full bypass)
#   shadow  — call Claude, log decision in ai_decision_log, DON'T honor
#   active  — call Claude AND honor the verdict
# Recommended rollout: flip to shadow → review ≥ 200 decisions via
# /api/ai-judge/decisions → promote to active.
AI_ENTRY_VETO_MODE=off
AI_NEWS_EXIT_MODE=off
AI_CONFIDENCE_MULT_MODE=off

# FRED (St. Louis Fed) API key — enables post-release macro values.
# Free, get one at fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# News sentiment backend.
#   vader    = lexicon-based, instant, ~65% accuracy on finance text (default)
#   finbert  = ~75-80% accuracy, requires `pip install transformers torch`
#              (~1GB image bloat, ~30s cold-start increase)
SENTIMENT_BACKEND=vader

# ─────── OPTIONAL — observability ────────────────────────────────────

# Structured JSON logs to stdout (Cloud Logging-friendly).
# Default 1 (on). Set to 0 for plaintext logs locally.
LOG_JSON=1

# Where local on-disk rotating file logs go. Defaults to backend/logs/.
LOG_DIR=

# ─────── OPTIONAL — operator notifications ───────────────────────────

# Webhook URL for critical alerts (Slack/Discord/Pagerduty-compatible).
# Posts JSON {severity, category, message, ticker?, trade_id?}.
ALERT_WEBHOOK_URL=
