# Secrets — never commit
.env
backend/.env

# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Logs
backend/logs/

# SQLite databases (r82: was previously only ignoring -shm/-wal/.bak —
# the actual *.db file was therefore committed; backend/stockapp.db
# leaked trade history + AutoTraderConfig + broker order IDs into git
# history. Use `git rm --cached backend/stockapp.db` to drop tracking.)
*.db
*.db-shm
*.db-wal
*.db.bak

# Frontend toolchain (r42 — esbuild-driven pre-bundle)
frontend/node_modules/
frontend/app.compiled.js.map
*.db
